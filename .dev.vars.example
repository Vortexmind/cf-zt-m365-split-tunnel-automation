# Cloudflare API credentials
CF_API_TOKEN=your_cloudflare_api_token_here
CF_ACCOUNT_ID=your_cloudflare_account_id_here

# Optional Cloudflare config
CF_POLICY_ID=

# Cloudflare Access authentication
# Set both to "dev" to bypass auth in local development
ACCESS_TEAM_DOMAIN=dev
ACCESS_POLICY_AUD=dev

# M365 endpoint configuration
M365_INSTANCE=Worldwide
M365_SERVICES=all
M365_CATEGORIES=Optimize,Allow

# Feature flags
INCLUDE_IPV6=true
INCLUDE_URLS=true

# Operational settings
MANAGED_TAG=[m365-auto]
DRY_RUN=true
MAX_ENTRIES=1000
